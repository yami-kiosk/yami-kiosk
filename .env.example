# =============================================================================
# YAMI KIOSK — Supabase (Syndicate Network)
# =============================================================================
# 1. Create project: https://supabase.com/dashboard
# 2. Copy this file → .env.local and paste URL + anon key from Settings → API
# 3. Run migrations (pick one):
#
#    A) Supabase CLI (local or linked remote):
#       npm run supabase:start    # optional local stack
#       npm run supabase:push     # apply migrations/
#
#    B) SQL Editor (hosted project — no CLI needed):
#       Paste & run in order:
#       - supabase/migrations/20260622120000_yami_backend.sql
#       - supabase/migrations/20260622130000_economy_rate_caps.sql
#       - supabase/migrations/20260622140000_server_active_income_cap.sql
#       - supabase/migrations/20260622150000_cheat_suspects_view.sql
#       - supabase/migrations/20260622160000_payout_address.sql
#       - supabase/migrations/20260622170000_season_claims.sql
#       - supabase/migrations/20260622180000_security_balance.sql
#
# 4. Deploy edge functions (required after migration 800):
#       supabase functions deploy syndicate-write
#       supabase functions deploy claim-reward
#
# 5. Verify: npm run supabase:check
# 6. Restart dev server: npm run dev
#
# URL format (NO trailing path):
#   VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
#   VITE_SUPABASE_ANON_KEY=eyJ... or sb_publishable_...
#
# On-chain claim (after token launch):
#   VITE_YAMI_MINT=YourPumpFunMintAddress
#   VITE_CLAIM_ENABLED=true
#
# Edge function secrets (supabase secrets set ...):
#   TREASURY_SECRET_KEY, YAMI_MINT, SOLANA_RPC_URL, YAMI_TOKEN_DECIMALS=6
#   Deploy: supabase functions deploy claim-reward
# =============================================================================

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# VITE_YAMI_MINT=
# VITE_CLAIM_ENABLED=false
